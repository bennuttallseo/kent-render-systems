---
import Layout from "../layouts/Layout.astro";
import ContactSection from "../components/ContactSection.astro";

const phoneHref = "tel:+447707564597";
const phone = "07707 564597"; // [confirm business number with Jack]

const heroStats = [
  { value: "20", unit: "yrs", label: "In the rendering trade" },
  { value: "4", unit: "", label: "Manufacturer accreditations" },
];

const heroPoints = [
  "Manufacturer-trained, approved installer",
  "Fully insured for peace of mind",
  "Manufacturer-backed guarantees",
  "Free, no-obligation quotes",
];

// [Confirm exact accreditation wording + source official badge artwork]
const accreditations = [
  { name: "Baumit", note: "Approved Installer" },
  { name: "Weber", note: "Registered Applicator" },
  { name: "EcoRend", note: "Registered Contractor" },
  { name: "EWI", note: "Accredited Installer" },
];

const services = [
  {
    name: "Silicone render",
    tag: "Most popular",
    body: "Silicone render is our most popular finish. A flexible, breathable, self-cleaning thin-coat render that resists cracking and holds its colours for years. It is water-repellent yet lets your walls breathe, protecting the wall beneath while keeping your home looking fresh. It is an ideal rendering choice for older and modern houses.",
    icon: "drop",
    img: "/images/silicone-render-bungalow-kent.png",
    imgAlt: "Bungalow finished in smooth white silicone render with bifold doors in Kent",
  },
  {
    name: "Monocouche rendering",
    tag: "One-coat",
    body: "Monocouche rendering is a through-coloured, one-coat finish that is hard-wearing and easy to live with. Because the colour runs all the way through, there is no painting needed, just a clean, modern finish. Monocouche rendering is applied for an even, consistent coat and a long-lasting finish.",
    icon: "layers",
    img: "/images/monocouche-render-detached-house-kent.jpg",
    imgAlt: "Detached house finished in white monocouche render with a tiled roof in Kent",
  },
];

const benefits = [
  {
    title: "Protects and preserves your walls",
    body: "External rendering shields your brickwork from driving rain, frost and moisture, helping to prevent damp and preserve the structure of the building for years. A well-applied, well maintained render is one of the best ways to protect and preserve a property.",
    icon: "shield",
  },
  {
    title: "Improves energy efficiency",
    body: "Combined with wall insulation, rendering helps keep heat inside your house, cutting bills and keeping rooms more comfortable through the year.",
    icon: "leaf",
  },
  {
    title: "Low maintenance and durable",
    body: "Modern rendering is self-cleaning, breathable and durable, so your walls stay fresh and well maintained with very little upkeep. That durability means fewer repairs over the life of the render.",
    icon: "drop",
  },
  {
    title: "Transforms your home's exterior",
    body: "A fresh render in the colours and textures of your choice will transform your home's exterior, enhance it and lift kerb appeal, making a real change to how your home looks and feels.",
    icon: "sparkle",
  },
  {
    title: "Built to last",
    body: "We use durable, manufacturer-approved materials and apply them correctly, so your rendering performs and protects your walls well into the future.",
    icon: "clock",
  },
];

const whyUs = [
  {
    title: "Nearly 20 years' experience",
    body: "Kent Render Systems is owner-led by Jack, a time-served renderer with almost two decades in the rendering and plastering trade across Kent. Jack takes the lead on every job, and our plastering expertise means each finish is delivered to a level a general builder cannot match. You deal with a real rendering and plastering specialist from start to finish.",
  },
  {
    title: "Manufacturer-approved installer",
    body: "We are approved applicators for Baumit, Weber and EcoRend, and an accredited EWI installer. That gives us the best rendering materials on the market and manufacturer-backed guarantees on every job we carry out.",
  },
  {
    title: "Quality workmanship, every time",
    body: "A skilled, reliable team, sharp detailing and a tidy site throughout. We machine spray our renders, the industry-leading method of application, for a more consistent, higher-quality finish. We treat your home and your walls with respect, take pride in the standard of our work and leave your house clean.",
  },
  {
    title: "Fully insured and local",
    body: "We are based in Kent and know the local housing and weather, and our services reach right across the county. We are fully insured, and clients across the county trust our rendering team on every project, with friendly support from quote to completion. Every job is fully covered by our insurance and manufacturer guarantees, and our plastering and rendering services run from first survey to final finish.",
  },
];

const renderTypes = [
  {
    name: "Silicone render",
    body: "Flexible, breathable and water-repellent, with excellent durability and a self-cleaning finish. The best all-round modern rendering choice for most homes.",
    us: true,
  },
  {
    name: "Monocouche render",
    body: "A through-coloured, one-coat finish that is quick to apply, ideal where a long-wearing, no-repaint result is the priority.",
    us: true,
  },
  {
    name: "Acrylic render",
    body: "A flexible thin-coat acrylic finish that resists cracking well, often used on walls prone to movement. Acrylic render is hard-wearing and comes in a wide range of colours.",
    us: true,
  },
  {
    name: "Sand & cement render",
    body: "We fit a modern, pre-bagged sand and cement render that is high polymer-based, which means it does not crack like traditional sand and cement. It is hard-wearing and versatile, and can be left bare or painted, giving older and newer walls a strong, durable finish without the brittleness of old-style cement render.",
    us: true,
  },
  {
    name: "Insulated render",
    body: "Insulated render is applied over a layer of insulation, combining a fresh finish with a genuine gain in warmth, protecting and insulating your walls in one job.",
    us: true,
  },
  {
    name: "Exterior wall coatings",
    body: "Protective exterior wall coatings can renew and weatherproof external walls where a full re-render is not required.",
    us: false,
  },
];

const process = [
  {
    step: "01",
    title: "Free survey and quote",
    body: "We visit, assess your walls and their condition, talk through your options and provide a clear, no-obligation quote.",
  },
  {
    step: "02",
    title: "Preparation",
    body: "Scaffolding goes up, the surface is prepared, and any repairs to the walls are carried out so the render has a sound base. Good preparation and repairs are what make a render last.",
  },
  {
    step: "03",
    title: "Machine-sprayed application",
    body: "We apply the render correctly, base coat, mesh and top coat, with both the base coats and the top coat machine sprayed. Spray application is the industry-leading method, delivering a more consistent, even and higher-quality finish across your walls than hand application alone.",
  },
  {
    step: "04",
    title: "Finishing and clean-up",
    body: "Final detailing and finishing, a thorough tidy, and a walk-round so you are delighted before we leave.",
  },
];

const areas = [
  "Maidstone", "Medway", "Canterbury", "Ashford", "Sittingbourne",
  "Faversham", "Folkestone", "Dover", "Deal", "Sandwich",
  "Margate", "Ramsgate", "Broadstairs", "Whitstable", "Herne Bay",
  "Tonbridge", "Tunbridge Wells", "Bromley", "Sidcup",
  "Chislehurst", "Orpington", "Bexley", "Bexleyheath", "Erith",
  "Eltham", "Swanley",
];

const faqs = [
  {
    q: "How much does rendering cost?",
    a: "Rendering cost depends on the size of your property, the condition of the walls, access and the render you choose. Scaffolding and surface repairs also affect the money involved. The best way to get an accurate cost is a free survey, after which we provide a clear, itemised quote, so you know exactly what your rendering will cost.",
  },
  {
    q: "How long does render last?",
    a: "Applied correctly, modern silicone rendering can look good and protect your walls for 20 to 30 years or more, with very little maintenance.",
  },
  {
    q: "Can you render over pebbledash and carry out repairs?",
    a: "In many cases, yes, provided the existing surface is sound. Where it is not, we carry out repairs or remove it first. We will advise on the best approach, and any repairs needed, during your survey.",
  },
  {
    q: "Silicone or monocouche, which is better?",
    a: "Both are excellent. Silicone render is more flexible and self-cleaning, while monocouche rendering is a hard-wearing, through-coloured, one-coat finish. We recommend the right render for your walls and budget.",
  },
  {
    q: "Do you do lime render for period or listed homes?",
    a: "Yes. Alongside modern silicone and monocouche systems, we offer lime render for period, heritage and listed homes. Modern lime render comes pre-bagged for a consistent, breathable finish, so we can supply and apply the right lime system to suit your walls.",
  },
  {
    q: "Will rendering help with damp?",
    a: "A sound, breathable render keeps moisture out of your walls and can help prevent damp, but it must be applied correctly over a properly prepared wall, which is exactly what we do.",
  },
  {
    q: "What guarantees do you offer?",
    a: "As an approved installer, our rendering is covered by manufacturer-backed guarantees for your peace of mind.",
  },
];

// Project gallery — each image targets a keyword (alt text + caption)
const gallery = [
  {
    src: "/images/rendering-kent.jpg",
    alt: "White silicone rendering on a detached house in Kent",
    caption: "Rendering, Kent",
  },
  {
    src: "/images/external-rendering-kent.jpg",
    alt: "External rendering with stone detailing on a modern extension in Kent",
    caption: "External rendering, Kent",
  },
  {
    src: "/images/render-job-kent.jpg",
    alt: "Completed silicone render job on a semi-detached house in Kent",
    caption: "Render job, Kent",
  },
  {
    src: "/images/new-build-house-rendering-kent.jpg",
    alt: "Newly rendered detached new-build house with brick plinth in Kent",
    caption: "New-build rendering, Kent",
  },
  {
    src: "/images/premium-render-extension-kent.jpg",
    alt: "Premium render extension with stone detailing and round windows in Kent",
    caption: "Render &amp; stone detailing, Kent",
  },
  {
    src: "/images/rendered-garden-room-kent.jpg",
    alt: "White rendered garden room with bifold doors in Kent",
    caption: "Garden room rendering, Kent",
  },
  {
    src: "/images/rendered-detached-house-brick-kent.jpg",
    alt: "Large detached house with cream render and red brick in Kent",
    caption: "Full house render, Kent",
  },
  {
    src: "/images/rendered-garden-feature-kent.jpg",
    alt: "Rendered garden BBQ and fireplace feature with rendered fence panels in Kent",
    caption: "Rendered garden feature, Kent",
  },
];

// Inline icon set
const icons: Record<string, string> = {
  drop: '<path d="M12 2.5s6 6.5 6 11a6 6 0 0 1-12 0c0-4.5 6-11 6-11Z"/>',
  layers: '<path d="m12 2 9 5-9 5-9-5 9-5Z"/><path d="m3 12 9 5 9-5"/><path d="m3 17 9 5 9-5"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/>',
  leaf: '<path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/>',
  sparkle: '<path d="M12 3v4M12 17v4M3 12h4M17 12h4M5.6 5.6l2.8 2.8M15.6 15.6l2.8 2.8M18.4 5.6l-2.8 2.8M8.4 15.6l-2.8 2.8"/>',
  clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  check: '<path d="M20 6 9 17l-5-5"/>',
};
---

<Layout>
  <!-- SECTION 1 — Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <p class="eyebrow hero-eyebrow">Baumit · Weber · EcoRend Approved Installer</p>
        <h1>Expert External Rendering in Kent</h1>
        <p class="hero-sub">
          Silicone and monocouche rendering systems, applied by a
          time-served specialist with nearly 20 years' experience. We protect,
          insulate and transform homes across Kent, backed by
          manufacturer-approved guarantees.
        </p>
        <div class="hero-cta">
          <a class="btn" href="#quote">Get Your Free Quote</a>
          <a class="btn btn--ghost" href="#quote">View Our Work</a>
        </div>
      </div>

      <aside class="hero-credentials">
        <p class="cred-title">Our credentials</p>
        <div class="cred-stats">
          {heroStats.map((s) => (
            <div class="cred-stat">
              <span class="cred-value">{s.value}{s.unit && <i>{s.unit}</i>}</span>
              <span class="cred-label">{s.label}</span>
            </div>
          ))}
        </div>
        <ul class="cred-points">
          {heroPoints.map((p) => (
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" set:html={icons.check} />
              {p}
            </li>
          ))}
        </ul>
      </aside>
    </div>
  </section>

  <!-- SECTION 2 — Accreditation bar -->
  <section class="trust-bar">
    <div class="container">
      <p class="trust-strap">Accredited and approved by the UK's leading render manufacturers.</p>
      <ul class="badge-row">
        {accreditations.map((a) => (
          <li class="badge">
            <span class="badge-name">{a.name}</span>
            <span class="badge-note">{a.note}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- SECTION 3 — Introduction -->
  <section class="section">
    <div class="container intro">
      <div class="intro-text">
      <div class="section-head">
        <p class="eyebrow">Kent Render Systems</p>
        <h2>Kent's external rendering specialists</h2>
      </div>
      <div class="intro-body">
        <p class="lead">
          Kent Render Systems is a specialist external rendering company
          providing professional rendering to homeowners, builders and clients
          across Kent. With nearly two decades in the rendering and plastering
          trade, we deliver durable external wall rendering that protects your
          home and transforms its appearance.
        </p>
        <p>
          Rendering is a skilled branch of plastering, and every rendering job we
          carry out is finished by hand to a high standard rather than rushed by
          a general builder. Our plastering background is what lets us deliver a
          flawless finish, because external rendering is plastering at its most
          demanding. From silicone render to monocouche rendering, we
          apply the right rendering services to suit your walls, your home and
          your budget. Whether you want to refresh tired walls, render a new
          build house, or protect an older property from damp and the Kent
          weather, our external wall rendering is built to preserve and beautify
          your home for the future.
        </p>
        <p>
          As experienced rendering and plastering contractors, we handle every
          rendering project across Kent with the same care, detail and pride in
          the finish, from a single wall to a full house rendering
          transformation.
        </p>
      </div>
      </div>
      <div class="intro-media">
        <img
          src="/images/silicone-render-detached-house-kent.jpg"
          alt="Silicone render on a newly built detached house in Kent"
          loading="lazy"
          width="800"
          height="1000"
        />
      </div>
    </div>
  </section>

  <!-- SECTION 4 — Services -->
  <section class="section section--sand" id="services">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">Our rendering services</p>
        <h2>Modern render systems, expertly applied</h2>
        <p class="lead">
          We specialise in three of the most popular modern rendering finishes,
          chosen to suit your home and the finish you want. These core services
          suit most homes, and we tailor our services to the home in front of us.
          All of our rendering services in Kent are carried out with the right
          materials and proper preparation. From small repairs to full-house
          projects, our services are tailored to your home and your walls.
        </p>
      </div>
      <div class="grid grid-2 services-grid">
        {services.map((s) => (
          <article class="card service-card">
            <div class="service-media">
              <img src={s.img} alt={s.imgAlt} loading="lazy" width="900" height="600" />
              <span class="pill">{s.tag}</span>
            </div>
            <div class="service-body">
              <span class="icon-badge">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={icons[s.icon]} />
              </span>
              <h3>{s.name}</h3>
              <p>{s.body}</p>
              <a class="text-link" href="#quote">{s.name} &rarr;</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 4b — Gallery -->
  <section class="section section--dark" id="gallery">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">Gallery</p>
        <h2>See the difference</h2>
        <p class="lead">
          Real Kent homes, transformed. Browse our before-and-after gallery to
          see the difference quality rendering makes and the finish we deliver on
          every job.
        </p>
      </div>
      <div class="carousel" data-carousel>
        <button class="carousel-btn carousel-prev" type="button" aria-label="Previous projects">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <ul class="carousel-track" data-carousel-track>
          {gallery.map((g) => (
            <li class="carousel-slide">
              <figure class="gallery-tile">
                <img src={g.src} alt={g.alt} loading="lazy" width="800" height="600" />
                <figcaption>{g.caption}</figcaption>
              </figure>
            </li>
          ))}
          <li class="carousel-slide">
            <div class="gallery-tile gallery-placeholder">
              <span class="ph-mark">+</span>
              <strong>More projects coming soon</strong>
              <small>New before &amp; after photos added regularly</small>
            </div>
          </li>
        </ul>
        <button class="carousel-btn carousel-next" type="button" aria-label="Next projects">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
      <div class="gallery-cta">
        <a class="btn btn--light" href="#quote">Get your project quoted</a>
      </div>
    </div>
  </section>

  <!-- SECTION 5 — Benefits -->
  <section class="section">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">Why render your home</p>
        <h2>What rendering does for your home</h2>
        <p class="lead">
          Quality rendering does far more than improve appearance. Good rendering
          protects, preserves and adds real value to your property.
        </p>
      </div>
      <div class="benefit-grid">
        {benefits.map((b) => (
          <article class="benefit">
            <span class="icon-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={icons[b.icon]} />
            </span>
            <div>
              <h3>{b.title}</h3>
              <p>{b.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 6 — Why choose us -->
  <section class="section section--dark" id="why-us">
    <div class="container why-grid">
      <div class="why-intro">
        <p class="eyebrow">Why choose Kent Render Systems</p>
        <h2>Rendering you can rely on</h2>
        <p class="lead">
          Rendering you can rely on, delivered by a genuine specialist.
        </p>
        <a class="btn btn--light" href="#quote">Get Your Free Quote</a>
      </div>
      <ul class="why-list">
        {whyUs.map((w) => (
          <li>
            <span class="why-check">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" set:html={icons.check} />
            </span>
            <div>
              <h3>{w.title}</h3>
              <p>{w.body}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- SECTION 7 — Render types explained -->
  <section class="section section--sand" id="render-types">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">Render systems explained</p>
        <h2>Which render is right for your home?</h2>
        <p class="lead">
          We specialise in modern silicone and monocouche rendering, but
          it helps to understand the main render types before you decide.
        </p>
      </div>
      <div class="grid grid-2 types-grid">
        {renderTypes.map((t) => (
          <article class={`type-card${t.us ? " type-card--us" : ""}`}>
            <div class="type-head">
              <h3>{t.name}</h3>
              {t.us && <span class="we-fit">We fit this</span>}
            </div>
            <p>{t.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 7b — Lime rendering (heritage) -->
  <section class="section lime-section" id="lime">
    <div class="container lime-grid">
      <div class="lime-media">
        <img
          src="/images/rendering-terraced-house-kent.jpg"
          alt="Smooth render on an older terraced property in Kent"
          loading="lazy"
          width="800"
          height="1000"
        />
      </div>
      <div class="lime-wrap">
      <div class="section-head">
        <p class="eyebrow">Period &amp; heritage homes</p>
        <h2>Lime rendering for period and heritage homes</h2>
      </div>
      <div class="lime-body">
        <p class="lead">
          Not every property suits a modern render, so we also offer lime
          rendering for older, period and heritage buildings. These walls were
          built to breathe, and lime render is often the most appropriate finish
          &mdash; flexing with the building and letting moisture escape rather
          than becoming trapped in the walls. That is why it is still specified
          for listed buildings, conservation areas and traditional solid-wall
          homes.
        </p>
        <p>
          Modern lime render now comes pre-bagged, making it a practical and
          consistent option. We supply and apply it where it is the right choice
          for your building, giving you a sympathetic, breathable finish without
          the guesswork.
        </p>
      </div>
      </div>
    </div>
    <div class="container">
      <div class="lime-cta">
        <div class="lime-cta-text">
          <h3>Got a period or listed building?</h3>
          <p>
            We fit lime render as well as modern silicone and monocouche
            systems, so we can finish a heritage home the way it should be
            finished. If you own a period or listed building and need a breathable
            lime render, get in touch and we will specify and apply the right,
            sympathetic finish for your walls.
          </p>
        </div>
        <div class="lime-cta-actions">
          <a class="btn btn--light" href="#quote">Get a Lime Render Quote</a>
          <a class="btn btn--on-dark btn--ghost" href={phoneHref}>Call {phone}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 8 — EWI -->
  <section class="section ewi" id="ewi">
    <div class="container ewi-grid">
      <div>
        <p class="eyebrow">External wall insulation</p>
        <h2>Render and insulation in one system</h2>
        <p class="lead">
          As an accredited external wall insulation installer, we do more than
          update your home's exterior. By fitting wall insulation beneath the
          render, external wall insulation improves efficiency, keeps your house
          warmer in winter, cuts heating bills and adds long-term value, all
          while giving your walls a clean, modern finish.
        </p>
        <p>
          External wall insulation is the ideal upgrade for solid-wall houses
          losing heat through cold walls. Our insulated render and wall insulation
          work combines the protection of a quality render with real comfort and
          warmth. Whether you need rendering alone or full wall insulation, we
          specify the right materials for your home for a finish built to last.
        </p>
        <a class="btn" href="#quote">Ask about external wall insulation</a>
      </div>
      <ul class="ewi-points">
        <li><strong>Warmer in winter</strong><span>Keeps heat where it belongs</span></li>
        <li><strong>Lower heating bills</strong><span>Real energy-efficiency gains</span></li>
        <li><strong>Adds long-term value</strong><span>A modern, insulated exterior</span></li>
        <li><strong>Ideal for solid walls</strong><span>Best fix for cold external walls</span></li>
      </ul>
    </div>
    <div class="container">
      <img
        class="ewi-media"
        src="/images/external-wall-insulation-render-kent.jpg"
        alt="Rendered single-storey extension with bifold doors on a brick house in Kent"
        loading="lazy"
        width="1000"
        height="630"
      />
    </div>
  </section>

  <!-- SECTION 9 — Process -->
  <section class="section section--sand-2" id="process">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">Our process</p>
        <h2>How we work</h2>
      </div>
      <ol class="process-grid">
        {process.map((p) => (
          <li class="process-step">
            <span class="process-num">{p.step}</span>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </li>
        ))}
      </ol>
