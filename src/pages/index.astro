    us: false,
  },
  {
    name: "Cement render",
    body: "The traditional sand and cement render. Cement render is hard-wearing and affordable, usually painted once cured, though it is less breathable and more prone to cracking than modern finishes. Many older houses were finished in cement render or pebbledash.",
    us: false,
  },
  {
    name: "Insulated render",
    body: "Insulated render is applied over a layer of insulation, combining a fresh finish with a genuine gain in warmth, protecting and insulating your walls in one job.",
    us: true,
  },
  {
    name: "Exterior wall coatings",
    body: "Protective exterior wall coatings can renew and weatherproof external walls where a full re-render is not required.",
    us: false,
  },
];

const process = [
  {
    step: "01",
    title: "Free survey and quote",
    body: "We visit, assess your walls and their condition, talk through your options and provide a clear, no-obligation quote.",
  },
  {
    step: "02",
    title: "Preparation",
    body: "Scaffolding goes up, the surface is prepared, and any repairs to the walls are carried out so the render has a sound base. Good preparation and repairs are what make a render last.",
  },
  {
    step: "03",
    title: "Application",
    body: "We apply the render correctly, base coat, mesh and top coat, to create a strong, even finish on your walls.",
  },
  {
    step: "04",
    title: "Finishing and clean-up",
    body: "Final detailing and finishing, a thorough tidy, and a walk-round so you are delighted before we leave.",
  },
];

const areas = [
  "Maidstone", "Medway", "Canterbury", "Ashford", "Sittingbourne",
  "Faversham", "Folkestone", "Dover", "Deal", "Sandwich",
  "Margate", "Ramsgate", "Broadstairs", "Whitstable", "Herne Bay",
  "Tonbridge", "Tunbridge Wells",
];

const faqs = [
  {
    q: "How much does rendering cost?",
    a: "Rendering cost depends on the size of your property, the condition of the walls, access and the render you choose. Scaffolding and surface repairs also affect the money involved. The best way to get an accurate cost is a free survey, after which we provide a clear, itemised quote, so you know exactly what your rendering will cost.",
  },
  {
    q: "How long does render last?",
    a: "Applied correctly, modern silicone and K-Rend rendering can look good and protect your walls for 20 to 30 years or more, with very little maintenance.",
  },
  {
    q: "Can you render over pebbledash and carry out repairs?",
    a: "In many cases, yes, provided the existing surface is sound. Where it is not, we carry out repairs or remove it first. We will advise on the best approach, and any repairs needed, during your survey.",
  },
  {
    q: "Silicone or monocouche, which is better?",
    a: "Both are excellent. Silicone render is more flexible and self-cleaning, while monocouche rendering is a hard-wearing, through-coloured, one-coat finish. We recommend the right render for your walls and budget.",
  },
  {
    q: "Do you do lime render for period or listed homes?",
    a: "We specialise in modern monocouche and K-Rend rendering. If you have a heritage home that may need traditional lime render, we will advise you on the most appropriate, breathable lime or modern option for your walls.",
  },
  {
    q: "Will rendering help with damp?",
    a: "A sound, breathable render keeps moisture out of your walls and can help prevent damp, but it must be applied correctly over a properly prepared wall, which is exactly what we do.",
  },
  {
    q: "What guarantees do you offer?",
    a: "As an approved installer, our rendering is covered by manufacturer-backed guarantees for your peace of mind.",
  },
];

// Project gallery — each image targets a keyword (alt text + caption)
const gallery = [
  {
    src: "/images/rendering-kent.jpg",
    alt: "White silicone rendering on a detached house in Kent",
    caption: "Rendering, Kent",
  },
  {
    src: "/images/external-rendering-kent.jpg",
    alt: "External rendering with stone detailing on a modern extension in Kent",
    caption: "External rendering, Kent",
  },
  {
    src: "/images/silicone-render-detached-house-kent.jpg",
    alt: "Silicone render on a newly built detached house in Kent",
    caption: "Silicone render, Kent",
  },
  {
    src: "/images/render-job-kent.jpg",
    alt: "Completed silicone render job on a semi-detached house in Kent",
    caption: "Render job, Kent",
  },
  {
    src: "/images/rendering-terraced-house-kent.jpg",
    alt: "Smooth render on an older terraced house in Kent",
    caption: "Terraced house rendering, Kent",
  },
];

// Inline icon set
const icons: Record<string, string> = {
  drop: '<path d="M12 2.5s6 6.5 6 11a6 6 0 0 1-12 0c0-4.5 6-11 6-11Z"/>',
  layers: '<path d="m12 2 9 5-9 5-9-5 9-5Z"/><path d="m3 12 9 5 9-5"/><path d="m3 17 9 5 9-5"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/>',
  leaf: '<path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/>',
  sparkle: '<path d="M12 3v4M12 17v4M3 12h4M17 12h4M5.6 5.6l2.8 2.8M15.6 15.6l2.8 2.8M18.4 5.6l-2.8 2.8M8.4 15.6l-2.8 2.8"/>',
  clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  check: '<path d="M20 6 9 17l-5-5"/>',
