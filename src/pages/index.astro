---

<Layout>
  <!-- SECTION 1 — Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <p class="eyebrow hero-eyebrow">Baumit · Weber · EcoRend Approved Installer</p>
      <h1>Expert External Rendering in Kent</h1>
      <p class="hero-sub">
        Silicone, monocouche and K-Rend rendering systems, applied by a
        time-served specialist with nearly 20 years' experience. We protect,
        insulate and transform homes across Kent, backed by
        manufacturer-approved guarantees.
      </p>
      <div class="hero-cta">
        <a class="btn" href="#quote">Get Your Free Quote</a>
        <a class="btn btn--ghost" href="#gallery">View Our Work</a>
      </div>
      <ul class="hero-trust">
        {heroTrust.map((t) => (
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" set:html={icons.check} />
            {t}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- SECTION 2 — Accreditation bar -->
  <section class="trust-bar">
    <div class="container">
      <p class="trust-strap">Accredited and approved by the UK's leading render manufacturers.</p>
      <ul class="badge-row">
        {accreditations.map((a) => (
          <li class="badge">
            <span class="badge-name">{a.name}</span>
            <span class="badge-note">{a.note}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- SECTION 3 — Introduction -->
  <section class="section">
    <div class="container intro">
      <div class="intro-text">
      <div class="section-head">
        <p class="eyebrow">Kent Render Systems</p>
        <h2>Kent's external rendering specialists</h2>
      </div>
      <div class="intro-body">
        <p class="lead">
          Kent Render Systems is a specialist external rendering company
          providing professional rendering to homeowners, builders and clients
          across Kent. With nearly two decades in the rendering and plastering
          trade, we deliver durable external wall rendering that protects your
          home and transforms its appearance.
        </p>
        <p>
          Rendering is a skilled branch of plastering, and every rendering job we
          carry out is finished by hand to a high standard rather than rushed by
          a general builder. Our plastering background is what lets us deliver a
          flawless finish, because external rendering is plastering at its most
          demanding. From silicone render and monocouche rendering to K-Rend, we
          apply the right rendering services to suit your walls, your home and
          your budget. Whether you want to refresh tired walls, render a new
          build house, or protect an older property from damp and the Kent
          weather, our external wall rendering is built to preserve and beautify
          your home for the future.
        </p>
        <p>
          As experienced rendering and plastering contractors, we handle every
          rendering project across Kent with the same care, detail and pride in
          the finish, from a single wall to a full house rendering
          transformation.
        </p>
      </div>
      </div>
      <div class="intro-media">
        <img
          src="/images/silicone-render-detached-house-kent.jpg"
          alt="Silicone render on a newly built detached house in Kent"
          loading="lazy"
          width="800"
          height="1000"
        />
      </div>
    </div>
  </section>

  <!-- SECTION 4 — Services -->
  <section class="section section--sand" id="services">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">Our rendering services</p>
        <h2>Modern render systems, expertly applied</h2>
        <p class="lead">
          We specialise in three of the most popular modern rendering finishes,
          chosen to suit your home and the finish you want. These core services
          suit most homes, and we tailor our services to the home in front of us.
          All of our rendering services in Kent are carried out with the right
          materials and proper preparation. From small repairs to full-house
          projects, our services are tailored to your home and your walls.
        </p>
      </div>
      <div class="grid grid-3">
        {services.map((s) => (
          <article class="card service-card">
            <span class="icon-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={icons[s.icon]} />
            </span>
            <span class="pill">{s.tag}</span>
            <h3>{s.name}</h3>
            <p>{s.body}</p>
            <a class="text-link" href="#quote">{s.name} &rarr;</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 5 — Benefits -->
  <section class="section">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">Why render your home</p>
        <h2>What rendering does for your home</h2>
        <p class="lead">
          Quality rendering does far more than improve appearance. Good rendering
          protects, preserves and adds real value to your property.
        </p>
      </div>
      <div class="benefit-grid">
        {benefits.map((b) => (
          <article class="benefit">
            <span class="icon-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={icons[b.icon]} />
            </span>
            <div>
              <h3>{b.title}</h3>
              <p>{b.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 6 — Why choose us -->
  <section class="section section--dark" id="why-us">
    <div class="container why-grid">
      <div class="why-intro">
        <p class="eyebrow">Why choose Kent Render Systems</p>
        <h2>Rendering you can rely on</h2>
        <p class="lead">
          Rendering you can rely on, delivered by a genuine specialist.
        </p>
        <a class="btn btn--light" href="#quote">Get Your Free Quote</a>
      </div>
      <ul class="why-list">
        {whyUs.map((w) => (
          <li>
            <span class="why-check">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" set:html={icons.check} />
            </span>
            <div>
              <h3>{w.title}</h3>
              <p>{w.body}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- SECTION 7 — Render types explained -->
  <section class="section section--sand" id="render-types">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">Render systems explained</p>
        <h2>Which render is right for your home?</h2>
        <p class="lead">
          We specialise in modern silicone, monocouche and K-Rend rendering, but
          it helps to understand the main render types before you decide.
        </p>
      </div>
      <div class="grid grid-2 types-grid">
        {renderTypes.map((t) => (
          <article class={`type-card${t.us ? " type-card--us" : ""}`}>
            <div class="type-head">
              <h3>{t.name}</h3>
              {t.us && <span class="we-fit">We fit this</span>}
            </div>
            <p>{t.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 7b — Lime rendering (heritage) -->
  <section class="section lime-section" id="lime">
    <div class="container lime-grid">
      <div class="lime-media">
        <img
          src="/images/rendering-terraced-house-kent.jpg"
          alt="Smooth render on an older terraced property in Kent"
          loading="lazy"
          width="800"
          height="1000"
        />
      </div>
      <div class="lime-wrap">
      <div class="section-head">
        <p class="eyebrow">Period &amp; heritage homes</p>
        <h2>Lime rendering for period and heritage homes</h2>
      </div>
      <div class="lime-body">
        <p class="lead">
          Not every property suits a modern render. Older, period and heritage
          buildings were built to breathe, and traditional lime render is often
          the most appropriate finish for them. Lime rendering has been used on
          buildings for centuries, and the natural breathability of lime and lime
          rendering lets moisture escape rather than becoming trapped in the
          walls.
        </p>
        <p>
          Where modern cement traps damp and can lead to cracking on an older
          wall, lime rendering flexes with the building and lets the walls
          breathe. That is why lime rendering is still specified for listed
          buildings, conservation areas and traditional solid-wall homes. Quality
          lime rendering handles movement and moisture far better than rigid
          alternatives, helping to preserve the original fabric and appearance of
          an older home.
        </p>
        <p>
          There are different types of lime rendering, from hydraulic lime to
          lime putty and lime-based systems, and the right specification depends
          on the age, construction and exposure of the building.
        </p>
      </div>
      </div>
    </div>
    <div class="container">
      <div class="lime-cta">
        <div class="lime-cta-text">
          <h3>Got a period or listed building?</h3>
          <p>
            We specialise in modern monocouche and K-Rend rendering, but we
            understand that lime rendering is sometimes the right answer for a
            heritage home. If you own a period or listed building and are weighing
            up lime rendering against a modern system, contact us and we will
            advise you honestly on the most appropriate, breathable rendering
            choice for your home.
          </p>
        </div>
        <div class="lime-cta-actions">
          <a class="btn btn--light" href="#quote">Get Honest Advice</a>
          <a class="btn btn--on-dark btn--ghost" href={phoneHref}>Call {phone}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 8 — EWI -->
  <section class="section ewi" id="ewi">
    <div class="container ewi-grid">
      <div>
        <p class="eyebrow">External wall insulation</p>
        <h2>Render and insulation in one system</h2>
        <p class="lead">
          As an accredited external wall insulation installer, we do more than
          update your home's exterior. By fitting wall insulation beneath the
          render, external wall insulation improves efficiency, keeps your house
          warmer in winter, cuts heating bills and adds long-term value, all
          while giving your walls a clean, modern finish.
        </p>
        <p>
          External wall insulation is the ideal upgrade for solid-wall houses
          losing heat through cold walls. Our insulated render and wall insulation
          work combines the protection of a quality render with real comfort and
          warmth. Whether you need rendering alone or full wall insulation, we
          specify the right materials for your home for a finish built to last.
        </p>
        <a class="btn" href="#quote">Ask about external wall insulation</a>
      </div>
      <ul class="ewi-points">
        <li><strong>Warmer in winter</strong><span>Keeps heat where it belongs</span></li>
        <li><strong>Lower heating bills</strong><span>Real energy-efficiency gains</span></li>
        <li><strong>Adds long-term value</strong><span>A modern, insulated exterior</span></li>
        <li><strong>Ideal for solid walls</strong><span>Best fix for cold external walls</span></li>
      </ul>
    </div>
  </section>

  <!-- SECTION 9 — Process -->
  <section class="section section--sand-2" id="process">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">Our process</p>
        <h2>How we work</h2>
      </div>
      <ol class="process-grid">
        {process.map((p) => (
          <li class="process-step">
            <span class="process-num">{p.step}</span>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- SECTION 10 — Areas -->
  <section class="section" id="areas">
    <div class="container">
      <div class="areas-grid">
      <div>
        <p class="eyebrow">Areas we cover</p>
        <h2>Rendering across Kent</h2>
        <p class="lead">
          We provide rendering services in Kent and the surrounding areas. Our
          rendering and plastering team covers Maidstone, Medway, Canterbury,
          Ashford, Sittingbourne, Faversham, Folkestone, Dover, Tonbridge and the
          Thanet towns, plus rendering in Tunbridge Wells and the wider West Kent
          area.
        </p>
        <p>
          Rendering in Tunbridge Wells is a regular part of our work, and
          rendering in Kent more widely, from Tunbridge Wells out to the coast.
          Our rendering services in Kent also reach toward the London borders for
          larger jobs, and from a single exterior rendering job to a full house
          rendering, the rendering Kent homeowners rely on is only a call away.
        </p>
        <p>
          Not sure if we cover you? Contact us. If you are in Kent, there is a
          good chance we can help. Rendering in Kent is our specialism, and our
          services cover the whole county.
        </p>
        <a class="btn btn--ghost" href="#quote">Check your area</a>
      </div>
      <div class="areas-map">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d19951.111763441968!2d0.8655301099013419!3d51.31316699323968!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47ded31a2458d20d%3A0x4bcb5d6aedb23f5a!2sJ%20T%20Plastering!5e0!3m2!1sen!2suk!4v1782011110027!5m2!1sen!2suk"
          title="Kent Render Systems service area map"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>
      </div>
      <ul class="area-tags">
        {areas.map((a) => <li>{a}</li>)}
      </ul>
    </div>
  </section>

  <!-- SECTION 11 — Gallery -->
  <section class="section section--dark" id="gallery">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">Gallery</p>
        <h2>See the difference</h2>
        <p class="lead">
          Real Kent homes, transformed. Browse our before-and-after gallery to
          see the difference quality rendering makes and the finish we deliver on
          every job.
        </p>
      </div>
      <div class="carousel" data-carousel>
        <button class="carousel-btn carousel-prev" type="button" aria-label="Previous projects">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <ul class="carousel-track" data-carousel-track>
          {gallery.map((g) => (
            <li class="carousel-slide">
              <figure class="gallery-tile">
                <img src={g.src} alt={g.alt} loading="lazy" width="800" height="600" />
                <figcaption>{g.caption}</figcaption>
              </figure>
            </li>
          ))}
          <li class="carousel-slide">
            <div class="gallery-tile gallery-placeholder">
              <span class="ph-mark">+</span>
              <strong>More projects coming soon</strong>
              <small>New before &amp; after photos added regularly</small>
            </div>
          </li>
