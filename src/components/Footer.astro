---
interface Props {
  phone: string;
  phoneHref: string;
  email: string;
}
const { phone, phoneHref, email } = Astro.props;
const year = new Date().getFullYear();

const services = ["Silicone Render", "Monocouche Render", "K-Rend", "External Wall Insulation"];
const areas = ["Maidstone", "Medway", "Canterbury", "Ashford", "Folkestone", "Tunbridge Wells"];
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <div class="brand">
        <span class="brand-mark">
          <img src="/logo-mark.png" alt="" width="40" height="40" />
        </span>
        <strong>Kent Render Systems</strong>
      </div>
      <p>
        Specialist external rendering across Kent — silicone, monocouche and
        K-Rend systems applied by a time-served installer with nearly 20 years'
        experience.
      </p>
      <p class="badges">Baumit · Weber · EcoRend Approved · EWI Accredited</p>
    </div>

    <div class="footer-col">
      <h4>Services</h4>
      <ul>{services.map((s) => <li><a href="#services">{s}</a></li>)}</ul>
    </div>

    <div class="footer-col">
      <h4>Areas We Cover</h4>
      <ul>{areas.map((a) => <li><a href="#areas">{a}</a></li>)}</ul>
    </div>

    <div class="footer-col">
      <h4>Get In Touch</h4>
      <ul class="contact">
        <li><a href={phoneHref}>{phone}</a></li>
        <li><a href={`mailto:${email}`}>{email}</a></li>
      </ul>
      <a class="btn btn--sm" href="#quote">Get Your Free Quote</a>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>&copy; {year} Kent Render Systems. All rights reserved.</p>
    <p>External rendering specialists serving Kent.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--charcoal);
    color: #aeb8c4;
    padding-top: 64px;
    font-size: 0.95rem;
  }
  .footer-grid {
    display: grid;
    gap: 36px;
    padding-bottom: 48px;
  }
  @media (min-width: 760px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1.3fr;
      gap: 40px;
    }
  }
  .footer-brand p {
    max-width: 38ch;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
  }
  .brand-mark {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    display: grid;
    place-items: center;
    background: #fff;
    flex: none;
  }
  .brand-mark img {
    width: 38px;
    height: 38px;
    object-fit: contain;
  }
  .brand strong {
    font-family: var(--font-display);
    color: #fff;
    font-size: 1.1rem;
  }
  .badges {
    color: var(--gold);
    font-size: 0.82rem;
    font-weight: 500;
  }
  .footer-col h4 {
    color: #fff;
    font-size: 0.82rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .footer-col ul {
    display: grid;
    gap: 10px;
  }
  .footer-col a:hover {
    color: var(--gold);
  }
  .contact a {
    font-weight: 600;
    color: #d8dee6;
  }
  .footer-col .btn {
    margin-top: 18px;
  }
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-block: 22px;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 8px;
    font-size: 0.85rem;
    color: #7d8896;
  }
  .footer-bottom p {
    margin: 0;
  }
</style>
